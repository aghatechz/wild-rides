# Wild Ride AWS Backend Configuration Template
# Copy this file to '.env' in the same directory and replace the values with your outputs from CloudFormation.

# The AWS region where your resources are deployed (e.g., us-east-1)
VITE_AWS_REGION=us-east-1

# Amazon Cognito User Pool ID (e.g., us-east-1_ab12XYZ)
VITE_COGNITO_USER_POOL_ID=your-cognito-user-pool-id

# Amazon Cognito User Pool App Client ID (e.g., 67abcdefghijkl...)
VITE_COGNITO_CLIENT_ID=your-cognito-app-client-id

# API Gateway Endpoint URL for unicorn dispatching (e.g., https://xxxx.execute-api.us-east-1.amazonaws.com/prod/ride)
VITE_API_GATEWAY_URL=your-api-gateway-endpoint-url
